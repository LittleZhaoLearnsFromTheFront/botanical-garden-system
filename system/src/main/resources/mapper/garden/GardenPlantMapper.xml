<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.garden.GardenPlantMapper">

    <resultMap type="GardenPlant" id="GardenPlantResult">
        <id     property="plantId"      column="plant_id"      />
        <result property="areaId"       column="area_id"       />
        <result property="areaName"     column="area_name"     />
        <result property="plantName"    column="plant_name"    />
        <result property="plantCode"    column="plant_code"    />
        <result property="species"      column="species"       />
        <result property="ageYears"     column="age_years"     />
        <result property="heightCm"     column="height_cm"     />
        <result property="healthStatus" column="health_status" />
        <result property="status"       column="status"        />
        <result property="delFlag"      column="del_flag"      />
        <result property="imageUrl"     column="image_url"     />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"       column="remark"        />
    </resultMap>

    <sql id="selectPlantVo">
        select p.plant_id, p.area_id, a.area_name, p.plant_name, p.plant_code, p.species, p.age_years, p.height_cm,
               p.health_status, p.status, p.del_flag, p.image_url, p.create_by, p.create_time, p.update_by, p.update_time, p.remark
        from garden_plant p
        left join garden_area a on a.area_id = p.area_id and a.del_flag = '0'
    </sql>

    <select id="selectPlantById" parameterType="Long" resultMap="GardenPlantResult">
        <include refid="selectPlantVo"/>
        where p.plant_id = #{plantId}
    </select>

    <select id="selectPlantList" parameterType="GardenPlant" resultMap="GardenPlantResult">
        <include refid="selectPlantVo"/>
        where p.del_flag = '0'
        <if test="plantName != null and plantName != ''">
            AND p.plant_name like concat('%', #{plantName}, '%')
        </if>
        <if test="plantCode != null and plantCode != ''">
            AND p.plant_code like concat('%', #{plantCode}, '%')
        </if>
        <if test="areaId != null">
            AND p.area_id = #{areaId}
        </if>
        <if test="healthStatus != null and healthStatus != ''">
            AND p.health_status = #{healthStatus}
        </if>
        <if test="status != null and status != ''">
            AND p.status = #{status}
        </if>
        order by p.plant_id desc
    </select>

    <insert id="insertPlant" parameterType="GardenPlant" useGeneratedKeys="true" keyProperty="plantId">
        insert into garden_plant(
            <if test="areaId != null">area_id,</if>
            <if test="plantName != null and plantName != ''">plant_name,</if>
            <if test="plantCode != null and plantCode != ''">plant_code,</if>
            <if test="species != null and species != ''">species,</if>
            <if test="ageYears != null">age_years,</if>
            <if test="heightCm != null">height_cm,</if>
            <if test="healthStatus != null and healthStatus != ''">health_status,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="imageUrl != null and imageUrl != ''">image_url,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="areaId != null">#{areaId},</if>
            <if test="plantName != null and plantName != ''">#{plantName},</if>
            <if test="plantCode != null and plantCode != ''">#{plantCode},</if>
            <if test="species != null and species != ''">#{species},</if>
            <if test="ageYears != null">#{ageYears},</if>
            <if test="heightCm != null">#{heightCm},</if>
            <if test="healthStatus != null and healthStatus != ''">#{healthStatus},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="imageUrl != null and imageUrl != ''">#{imageUrl},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updatePlant" parameterType="GardenPlant">
        update garden_plant
        <set>
            <if test="areaId != null">area_id = #{areaId},</if>
            <if test="plantName != null and plantName != ''">plant_name = #{plantName},</if>
            <if test="plantCode != null">plant_code = #{plantCode},</if>
            <if test="species != null">species = #{species},</if>
            <if test="ageYears != null">age_years = #{ageYears},</if>
            <if test="heightCm != null">height_cm = #{heightCm},</if>
            <if test="healthStatus != null and healthStatus != ''">health_status = #{healthStatus},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="imageUrl != null">image_url = #{imageUrl},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where plant_id = #{plantId}
    </update>

    <delete id="deletePlantById" parameterType="Long">
        update garden_plant set del_flag = '2' where plant_id = #{plantId}
    </delete>

    <delete id="deletePlantByIds" parameterType="Long">
        update garden_plant set del_flag = '2' where plant_id in
        <foreach item="plantId" collection="array" open="(" separator="," close=")">
            #{plantId}
        </foreach>
    </delete>

</mapper>

